# Copy this file to .env for local runs.
#
# Without OPENAI_API_KEY the pipeline falls back to mock mode so the workflow
# can be demonstrated end-to-end. Mock output is only for smoke tests and must
# not be used as the final course submission.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Default is auto-detected. Kimi / Moonshot-compatible endpoints default to 1,
# while standard OpenAI models default to 0 for deterministic extraction.
LLM_TEMPERATURE=

# Network guardrails for OpenAI-compatible providers.
LLM_REQUEST_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=1
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_BACKOFF_SECONDS=4

# For final runs, set true to avoid saving mock-fallback cards after API errors.
LLM_STRICT=false

# Optional: force mock mode even when an API key exists.
LLM_MOCK=false
